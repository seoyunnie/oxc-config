{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@seoyunnie/oxc-config",
  "version": "1.1.0",
  "description": "Seoyun's shared base configurations for Oxlint and Oxfmt.",
  "keywords": [
    "oxc",
    "oxfmt",
    "oxfmt-config",
    "oxlint",
    "oxlint-config"
  ],
  "homepage": "https://github.com/seoyunnie/oxc-config#readme",
  "bugs": {
    "url": "https://github.com/seoyunnie/oxc-config/issues"
  },
  "license": "MIT",
  "author": "Seoyun",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seoyunnie/oxc-config.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./oxfmt": "./src/oxfmt.ts",
    "./oxlint": "./src/oxlint/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./oxfmt": "./dist/oxfmt.js",
      "./oxlint": "./dist/oxlint.js",
      "./package.json": "./package.json"
    },
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "fmt": "oxfmt",
    "fmt:check": "pnpm run fmt --check",
    "lint": "oxlint",
    "lint:fix": "pnpm run lint --fix"
  },
  "devDependencies": {
    "@tsconfig/node-ts": "^23.6.4",
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/recommended": "^1.0.13",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^24.12.2",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "oxfmt": ">=0.46.0",
    "oxlint": ">=1.61.0",
    "oxlint-tsgolint": ">=0.21.1"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820"
}
